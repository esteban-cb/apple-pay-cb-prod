---
import Layout from '../layouts/Layout.astro';
import ApplePayApp from '../components/ApplePayApp';
---

<Layout>
  <div class="min-h-screen flex flex-col items-center justify-center px-4 py-16">
    <!-- Logo + title -->
    <div class="flex items-center gap-3 mb-8">
      <img src="/icon.png" alt="Coinbase" class="w-10 h-10 rounded-xl" />
      <div>
        <p class="text-xs text-gray-600 uppercase tracking-widest">Coinbase</p>
        <h1 class="text-white font-bold text-lg leading-none">Onramp</h1>
      </div>
    </div>

    <!-- Widget -->
    <div class="w-full max-w-md">
      <ApplePayApp client:only="react" />
    </div>

    <p class="mt-6 text-xs text-gray-700">
      <a href="https://docs.cdp.coinbase.com/onramp/headless-onramp/overview" target="_blank" rel="noopener noreferrer" class="hover:text-gray-500 transition-colors">
        API docs →
      </a>
    </p>
  </div>
</Layout>
