# CDP API Credentials — get from https://portal.cdp.coinbase.com/access/api
CDP_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CDP_API_SECRET=your-base64-encoded-ed25519-private-key==

# Coinbase App ID — get from https://portal.cdp.coinbase.com/
COINBASE_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Allowed CORS origins (comma-separated). Add your Vercel domain after deploy.
ALLOWED_ORIGINS=http://localhost:4321,https://your-app.vercel.app
